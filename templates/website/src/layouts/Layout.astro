---
import '../styles/global.css'
import { Font } from 'astro:assets'
import Nav from '../components/primitives/Nav.astro'
import Footer from '../components/primitives/Footer.astro'
import { SITE_TITLE, NAV_LINKS } from '../consts'

interface Props {
  title: string
  description: string
  /** Root-relative path to the 1200x630 share image. The default ships as SVG
   *  so the template stays light; swap it for a PNG before launch (some
   *  scrapers reject SVG og:images). skil_website-quality dimension 2. */
  image?: string
  /** Open Graph type: 'website' for a landing page, 'article' for a post. */
  type?: 'website' | 'article'
}

const { title, description, image = '/og-default.svg', type = 'website' } = Astro.props

// Canonical, sitemap, and the absolute og:image all derive from `site` in
// astro.config. Without it they would be relative and silently break sharing
// and SEO, so refuse to render rather than ship a broken head.
const site = Astro.site
if (!site) {
  throw new Error(
    'astro.config `site` is unset: canonical / sitemap / og:url need the production origin.',
  )
}
const canonical = new URL(Astro.url.pathname, site)
const ogImage = new URL(image, site)

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: title,
  url: canonical.href,
  description,
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Self-hosted faces: emits @font-face + preloads the two render-critical
        faces (display, body). Mono is not preloaded (it appears below the fold,
        in code), so the browser fetches it lazily. */}
    <Font cssVariable="--ff-display" preload />
    <Font cssVariable="--ff-body" preload />
    <Font cssVariable="--ff-mono" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonical.href} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen bg-bg font-body text-base text-text antialiased">
    <a class="skip-link rounded-md bg-brand px-3 py-2 font-medium text-bg" href="#main">Skip to content</a>
    <Nav brand={SITE_TITLE} links={NAV_LINKS} />
    <main id="main">
      <slot />
    </main>
    <Footer brand={SITE_TITLE} />
  </body>
</html>
