---
// Section: the content wrapper every page is built from. It owns the horizontal
// container (max width + gutter) and the vertical rhythm, nothing else, so it
// imposes no layout language on what goes inside. Alternate `tone` between
// neighbours to give the page rhythm without a divider on every edge.
interface Props {
  // `tag`, not `as`: `as` is a TS keyword and breaks Astro's Props inference here.
  tag?: 'section' | 'div' | 'article' | 'aside'
  tone?: 'base' | 'surface'
  width?: 'default' | 'wide' | 'full'
  id?: string
  class?: string
}
const { tag: Tag = 'section', tone = 'base', width = 'default', id, class: className = '' } = Astro.props
const toneClass = tone === 'surface' ? 'bg-surface' : 'bg-bg'
const widthClass = width === 'wide' ? 'max-w-7xl' : width === 'full' ? 'max-w-none' : 'max-w-5xl'
---

<Tag id={id} class:list={[toneClass, className]}>
  <div class:list={['mx-auto px-6 py-16 sm:py-20', widthClass]}>
    <slot />
  </div>
</Tag>
