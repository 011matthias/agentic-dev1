---
import Layout from '../layouts/Layout.astro'
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts'

// Placeholder feature copy. A real product replaces every word here from
// PRODUCT.md; generic copy reads as templated (skil_website-quality dim 5).
const features = [
  {
    title: 'Found on the quality bar',
    body: 'Canonical URLs, Open Graph and Twitter cards, JSON-LD, and a sitemap ship wired, not bolted on.',
  },
  {
    title: 'Accessible by default',
    body: 'Landmarks, a skip link, visible focus, and reduced-motion are in the floor, so every page starts compliant.',
  },
  {
    title: 'Fast by construction',
    body: 'Astro ships zero JavaScript by default; Tailwind keeps the CSS small. Performance is the starting state.',
  },
]
---

<Layout title={`${SITE_TITLE}: ${SITE_TAGLINE}`} description={SITE_DESCRIPTION}>
  <section class="mx-auto max-w-5xl px-6 py-24">
    <p class="text-sm font-medium uppercase tracking-widest text-accent">{SITE_TITLE}</p>
    <h1 class="mt-3 max-w-3xl text-balance text-5xl font-semibold tracking-tight">
      {SITE_TAGLINE}
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-muted">{SITE_DESCRIPTION}</p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/#features"
        class="rounded-md bg-ink px-5 py-3 font-medium text-paper transition-colors hover:bg-accent"
      >
        See what ships
      </a>
      <a href="/#about" class="rounded-md px-5 py-3 font-medium text-ink underline-offset-4 hover:underline">
        Read the brief
      </a>
    </div>
  </section>

  <section id="features" class="border-t border-ink/10 bg-ink/[0.02]">
    <div class="mx-auto max-w-5xl px-6 py-20">
      <h2 class="text-3xl font-semibold tracking-tight">What ships in the box</h2>
      <ul class="mt-10 grid gap-8 sm:grid-cols-3">
        {
          features.map((feature) => (
            <li>
              <h3 class="text-lg font-semibold">{feature.title}</h3>
              <p class="mt-2 text-muted">{feature.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section id="about" class="mx-auto max-w-5xl px-6 py-20">
    <h2 class="text-3xl font-semibold tracking-tight">About this starter</h2>
    <p class="mt-6 max-w-2xl text-lg text-muted">
      This is the bare archetype: replace the copy, the palette in
      <code>src/styles/global.css</code>, and the constants in <code>src/consts.ts</code>
      with your own. Run <code>npm run verify</code> for the static quality gate and
      <code>npm run verify:lighthouse</code> for the performance budget.
    </p>
  </section>
</Layout>
