---
// Faq: a stack of JS-free accordions (<details>/<summary>). Each row is keyboard-
// operable natively and the chevron reflects open state via the `open` group
// variant. Use a real <h3> inside <summary> so the questions join the heading
// outline (an FAQ is a list of headed answers, structure-encodes-meaning).
interface FaqItem {
  q: string
  a: string
}
interface Props {
  items: FaqItem[]
}
const { items } = Astro.props
---

<div class="divide-y divide-border overflow-hidden rounded-lg border border-border">
  {
    items.map((item) => (
      <details class="group">
        <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4">
          <h3 class="font-display text-base font-bold text-text">{item.q}</h3>
          <svg
            class="shrink-0 text-text-muted transition group-open:rotate-180"
            width="18"
            height="18"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <polyline points="5 8 10 13 15 8" />
          </svg>
        </summary>
        <div class="px-5 pb-5 text-text-muted">{item.a}</div>
      </details>
    ))
  }
</div>

<style>
  summary {
    list-style: none;
  }
  summary::-webkit-details-marker {
    display: none;
  }
</style>
